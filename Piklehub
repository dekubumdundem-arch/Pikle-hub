local flingDebounce = {}

local function flingTarget(otherChar)
	if not state.walkFling then return end
	if not root then return end
	if not otherChar then return end
	if otherChar == char then return end

	local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
	if not otherRoot then return end

	if flingDebounce[otherChar] then return end
	flingDebounce[otherChar] = true

	local dir = (otherRoot.Position - root.Position)
	if dir.Magnitude == 0 then return end
	dir = dir.Unit

	local impulse = (dir * 140 + Vector3.new(0, 80, 0)) * otherRoot.AssemblyMass
	otherRoot:ApplyImpulse(impulse)

	task.delay(0.5, function()
		flingDebounce[otherChar] = nil
	end)
end

local function bindFling(character)
	if not character then return end

	for _,part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Touched:Connect(function(hit)
				if not state.walkFling then return end

				local otherChar = hit:FindFirstAncestorOfClass("Model")
				if not otherChar then return end
				if otherChar == character then return end

				flingTarget(otherChar)
			end)
		end
	end
end

bindFling(char)

player.CharacterAdded:Connect(function(c)
	task.wait(0.5)
	hookCharacter(c)
	bindFling(c)
end)

