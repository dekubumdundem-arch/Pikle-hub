RunService.RenderStepped:Connect(function()
	if not state.enabled then return end
	if not hum or not root then return end

	if state.sprint and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
		hum.WalkSpeed = state.speed + 30
	else
		hum.WalkSpeed = state.speed
	end

	hum.JumpPower = state.jump
	camera.FieldOfView = 70

	-- fly
	if state.fly then
		if not flyVel then
			flyVel = Instance.new("BodyVelocity")
			flyVel.MaxForce = Vector3.new(1e9,1e9,1e9)
			flyVel.Parent = root
		end

		local dir = Vector3.zero
		local cam = camera

		if UIS:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
		if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end

		flyVel.Velocity = dir.Magnitude > 0 and dir.Unit * 60 or Vector3.zero
	else
		stopFly()
	end

	-- noclip
	if state.noclip then
		for _,v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end

	-- spin
	if state.spin and root then
		root.CFrame *= CFrame.Angles(0, math.rad(8), 0)
	end
end)

-- infinite jump
UIS.JumpRequest:Connect(function()
	if state.infJump and hum then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)

